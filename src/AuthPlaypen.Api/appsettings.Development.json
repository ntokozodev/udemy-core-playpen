{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AdminApp": {
    "UseMockData": "true",
    "Oidc": {
      "EnableAuth": "false",
      "Authority": "https://localhost:5100",
      "ClientId": "gatekeeper-web-admin",
      "RedirectPath": "/auth/callback",
      "PostLogoutRedirectPath": "/"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "LocalAuth": {
    "Issuer": "https://authplaypen.local",
    "Audience": "authplaypen-resource-apis",
    "SigningKey": "dev-local-signing-key-change-me-1234567890",
    "AccessTokenLifetimeSeconds": "3600"
  }
}
