{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=auth_playpen;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "TenantId": "common",
    "ClientId": "",
    "Audience": "api://authplaypen-api",
    "Scope": "api://authplaypen-api/access_as_user",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc"
  },
  "OpenIddictSigningOptions": {
    "Issuer": "https://localhost:5100",
    "SigningCertificatePath": "",
    "SigningCertificatePassword": ""
  },
  "LocalAuth": {
    "Issuer": "https://authplaypen.local",
    "Audience": "authplaypen-resource-apis",
    "SigningKey": "dev-local-signing-key-change-me-1234567890",
    "AccessTokenLifetimeSeconds": "3600",
    "EnableIntrospectionEndpoint": "true"
  }
}
