# Set to true to run the admin UI against in-memory mock data.
VITE_USE_MOCK_DATA=false

# Set to true to require OIDC authentication for admin routes.
VITE_ENABLE_OIDC_AUTH=false

# OIDC authority (issuer) for the API/OpenIddict host.
VITE_API_OIDC_AUTHORITY=https://api-host-or-openiddict-host

# OIDC client id registered for the admin SPA.
VITE_API_OIDC_CLIENT_ID=admin-client-id

# Optional SPA redirect paths.
VITE_OIDC_REDIRECT_PATH=/admin/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_PATH=/admin
